# Server configuration
PORT=3001

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Admin API key for write operations (generate a strong random key)
ADMIN_API_KEY=change-me-to-a-random-secret-key

# Data file path (relative to backend directory)
DATA_FILE=data.json

# Redis configuration (optional — falls back to in-memory)
# REDIS_URL=redis://localhost:6379
# CACHE_TTL_SECONDS=60

# Sentry error tracking (optional — error tracking is disabled when unset)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Logging
# LOG_LEVEL=info
# NODE_ENV=development
