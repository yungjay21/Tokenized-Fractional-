{
  "name": "rwa-marketplace-backend",
  "version": "2.0.0",
  "description": "Off-chain metadata API for RWA marketplace",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./__tests__/setup.js",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "__tests__/setup.js"
    ],
    "transform": {}
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
